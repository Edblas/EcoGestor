# Porta publicada para acesso dos usuarios no navegador
FRONTEND_PORT=80

# Banco de dados PostgreSQL
POSTGRES_DB=ecogestor
POSTGRES_USER=ecogestor
POSTGRES_PASSWORD=troque-esta-senha-por-uma-forte

# JWT base64. Gere um novo valor com:
# openssl rand -base64 32
JWT_SECRET=VGhpc0lzQVN0cm9uZ0pXVFNlY3JldEtleUZvclByb2R1Y3Rpb24xMjM0NQ==
JWT_EXPIRATION=86400000

# Memoria da JVM do backend
JAVA_OPTS=-Xms256m -Xmx1024m
